# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server-only, never expose to client

# ─── Cloudinary ─────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: signed-upload preset name (created in Cloudinary dashboard)
CLOUDINARY_UPLOAD_PRESET=memorypin_signed

# ─── OpenAI (optional "make it poetic" — costs money, off by default) ───
# Leave both unset to keep the app 100% free (stories are user-written).
# To enable AI polish: set the key AND NEXT_PUBLIC_AI_ENABLED=true.
OPENAI_API_KEY=
NEXT_PUBLIC_AI_ENABLED=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # set to https://yourdomain.com in prod

# ─── Optional: Google Photos import (Picker API) ────────────
# Web OAuth client ID (same project as Supabase Google sign-in).
# Requires: enable "Photos Picker API" + add the photospicker scope.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Optional: Mapbox (geocoding new pins, Phase 2) ─────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
